# Binary (root only, not cmd/cyntr/ directory)
/cyntr
/bin/
*.exe

# Demo runtime dirs
demos/**/.run/

# Runtime data
*.db
*.db-shm
*.db-wal

# Generated config (created by cyntr init)
cyntr.yaml
policy.yaml
cloud-ops-agent.json
# But always include demo configs
!demos/**/cyntr.yaml
!demos/**/policy.yaml

# Environment
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test
*.test
*.out
coverage.txt
