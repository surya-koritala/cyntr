# deploy/hosted.env.example
#
# Copy to `.env` next to docker-compose.hosted.yml. Every value is a
# placeholder — fill in only what you need; cyntr no-ops cleanly on missing
# optional vars.
#
# Loaded by: docker compose -f deploy/docker-compose.hosted.yml --env-file .env up -d

# ---------- core (required-ish) ----------
# Public hostname pointing at this Docker host. Caddy issues TLS for this.
CYNTR_DOMAIN=try.cyntr.dev
# ACME contact email — Let's Encrypt sends expiry warnings here.
CYNTR_TLS_EMAIL=admin@cyntr.dev
# Identifies this node in federation handshakes and audit log entries.
CYNTR_NODE_ID=cyntr-hosted-iad
# Pinned image tag baked into VERSION at build time.
CYNTR_VERSION=hosted-beta

# ---------- LLM providers (pick at least one) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Multiple models (comma-separated) override ANTHROPIC_MODEL:
# ANTHROPIC_MODELS=claude-sonnet-4-20250514,claude-haiku-4-20250514

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Azure OpenAI (set all three or none):
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# OpenRouter (single-token gateway to most providers):
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Self-hosted models via Ollama (set OLLAMA_URL + comma-separated OLLAMA_MODELS):
OLLAMA_URL=
OLLAMA_MODELS=

# Gemini:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ---------- observability ----------
# Point at any OTLP-HTTP-compatible collector (jaeger, otel-collector, grafana
# tempo, honeycomb, etc.). Empty = disabled, zero overhead.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=cyntr-hosted

# ---------- channels (intentionally OFF for the hosted free-tier) ----------
# Every adapter below is gated on its primary token env var being non-empty —
# leaving them blank keeps the multi-tenant cyntr instance free of stray
# Slack / Twilio / WhatsApp listeners that would bind ports the upstream
# proxy isn't expecting. If you want one on, fill the section AND remove
# `channels.enabled: false` (where applicable) from hosted.cyntr.yaml.example.
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---------- security ----------
# Optional: gate the public API behind a single bearer token. Recommended
# while the platform is in private beta. Empty = no API auth (dashboard +
# API are reachable by anyone with the URL).
CYNTR_API_KEY=

# ---------- packs ----------
# Vertical packs ship opt-in. Loomfeed is OFF for hosted (it's the consumer
# product, not a B2B tool). Operators self-hosting can flip these to 1.
CYNTR_PACK_LOOMFEED=0
